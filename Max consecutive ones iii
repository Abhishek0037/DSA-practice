class Solution(object):
    def longestOnes(self, nums, k):
        l=0
        zeros=0
        maxy =0 #maxvalue
        for r in range (len(nums)):
            if nums[r]==0:
                zeros+=1
            if zeros>k:
                if nums[l]==0:
                    zeros-=1
                l+=1
            maxy=max(maxy,r-l+1)
        return maxy
                
            
 
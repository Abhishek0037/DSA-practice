class Solution(object):
    def numSubarrayProductLessThanK(self, nums, k):
        if k<=1: return 0

        l=0
        pdt=1
        cnt=0
        for r in range(len(nums)):
            pdt*=nums[r]
            while pdt>=k:
                pdt//=nums[l]
                l+=1
            cnt+=(r-l+1)
        return cnt